{
  "name": "talktype",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "lsof -ti:5173 | xargs kill -9 2>/dev/null || true && vite dev --port 5173 --host",
    "build": "vite build",
    "deploy:pi": "bash scripts/deploy-pi.sh",
    "package:extension": "bash scripts/package-extension.sh",
    "preview": "vite preview",
    "sync:onnx": "node scripts/sync-onnx-wasm.mjs",
    "prepare": "svelte-kit sync || echo '' ; node scripts/sync-onnx-wasm.mjs",
    "postinstall": "node scripts/stub-sharp.js",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "lighthouse": "npm run build && lhci autorun",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "0.15.1",
    "@sveltejs/adapter-netlify": "6.0.4",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "happy-dom": "20.9.0",
    "jsdom": "^26.1.0",
    "postcss-import": "^15.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "svelte": "^5.0.0",
    "tailwindcss": "^3.4.19",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@dicebear/collection": "9.4.2",
    "@dicebear/core": "9.4.2",
    "@google/genai": "1.52.0",
    "@huggingface/transformers": "4.2.0",
    "@netlify/blobs": "10.7.7",
    "daisyui": "^4.12.23",
    "fflate": "0.8.3",
    "qrcode": "1.5.4"
  },
  "overrides": {
    "cookie": "0.7.2",
    "protobufjs": "7.5.8",
    "sharp": "0.34.5",
    "tmp": "0.2.7"
  }
}

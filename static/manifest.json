{
	"name": "TalkType",
	"short_name": "TalkType",
	"description": "Fast, free voice-to-text with live transcription and private offline mode.",
	"id": "/?source=pwa",
	"start_url": "/?source=pwa",
	"display": "standalone",
	"display_override": ["standalone", "minimal-ui", "browser"],
	"background_color": "#FFF6E6",
	"theme_color": "#FFF6E6",
	"orientation": "portrait-primary",
	"categories": ["utilities", "productivity"],
	"icons": [
		{
			"src": "/appicon/web/icon-192.png",
			"sizes": "192x192",
			"type": "image/png",
			"purpose": "any"
		},
		{
			"src": "/appicon/web/icon-512.png",
			"sizes": "512x512",
			"type": "image/png",
			"purpose": "any"
		},
		{
			"src": "/appicon/web/icon-192-maskable.png",
			"sizes": "192x192",
			"type": "image/png",
			"purpose": "maskable"
		},
		{
			"src": "/appicon/web/icon-512-maskable.png",
			"sizes": "512x512",
			"type": "image/png",
			"purpose": "maskable"
		}
	],
	"shortcuts": [
		{
			"name": "Start Recording",
			"short_name": "Record",
			"description": "Start a new voice recording",
			"url": "/?action=record&source=shortcut",
			"icons": [{ "src": "/appicon/web/icon-192.png", "sizes": "192x192" }]
		}
	],
	"screenshots": [
		{
			"src": "/screenshots/screenshot-mobile.png",
			"sizes": "390x844",
			"type": "image/png",
			"form_factor": "narrow",
			"label": "TalkType ready to record on mobile"
		},
		{
			"src": "/screenshots/screenshot-wide.png",
			"sizes": "1280x720",
			"type": "image/png",
			"form_factor": "wide",
			"label": "TalkType voice transcription workspace"
		}
	],
	"related_applications": [
		{
			"platform": "webapp",
			"url": "/manifest.json",
			"id": "/?source=pwa"
		}
	],
	"prefer_related_applications": false,
	"scope": "/",
	"launch_handler": {
		"client_mode": ["navigate-existing", "auto"]
	}
}

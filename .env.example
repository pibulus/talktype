# TalkType Environment Variables
# Copy this file to .env and fill in your values

# Gemini API Key (required)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
DEEPGRAM_API_KEY=your_deepgram_api_key_here
API_AUTH_TOKEN=choose_a_secret_value
ALLOWED_ORIGINS=http://localhost:5173
API_RATE_LIMIT=5
API_RATE_WINDOW_MS=60000
API_SESSION_TTL_MS=14400000
API_COOKIE_SECRET=replace_with_random_32_chars

# Manual supporter unlocks.
# Comma-separated and matched case-insensitively by /api/validate-code.
SUPPORTER_UNLOCK_CODES=TALKTYPE-EXAMPLE-CODE
PUBLIC_FORCE_SUPPORTER_MODE=false
API_COOKIE_SECURE=false
MAX_UPLOAD_BYTES=52428800

# Optional: Development settings
# VITE_DEBUG=false
# VITE_API_TIMEOUT=30000

# PostHog Analytics (optional)
# Get your project key from: https://app.posthog.com/project/settings
# VITE_POSTHOG_KEY=phc_your_project_key_here
# VITE_POSTHOG_HOST=https://app.posthog.com
